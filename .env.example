# =============================================================
# Golden Abode — Root Environment Variables
# Copy this file to .env and fill in real values.
# Never commit .env to version control.
# =============================================================

# ─── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── PostgreSQL ───────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=golden_abode
DB_USER=postgres
DB_PASS=postgres

# ─── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ──────────────────────────────────────────────────────
# Access token secret — min 32 random chars in production
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
# Access token expiry (e.g. 15m, 1h)
JWT_ACCESS_EXPIRES_IN=15m

# Onboarding token secret (for pre-registration flow)
JWT_ONBOARDING_SECRET=change_me_onboarding_secret_min_32_chars
JWT_ONBOARDING_EXPIRES_IN=15m

# Refresh token TTL in days
REFRESH_TOKEN_TTL_DAYS=30

# ─── Admin registration ───────────────────────────────────────
# Required to create the first (and later) admin accounts via /auth/admin/register
ADMIN_REGISTRATION_SECRET=change_me_admin_registration_secret_min_16_chars

# ─── MSG91 ────────────────────────────────────────────────────
# Set to true only after MSG91 DLT template is approved
USE_MSG91_SMS=false
MSG91_AUTH_KEY=your_msg91_auth_key_here
MSG91_TEMPLATE_ID=your_msg91_template_id_here
MSG91_SENDER_ID=GOLDEN

# ─── Rate Limiting ────────────────────────────────────────────
# Max OTP send attempts per hour per phone
THROTTLE_OTP_SEND_LIMIT=3
THROTTLE_OTP_SEND_TTL=3600

# Max OTP verify failed attempts per 10 min per phone
THROTTLE_OTP_VERIFY_LIMIT=5
THROTTLE_OTP_VERIFY_TTL=600
