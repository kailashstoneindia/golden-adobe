{
  "name": "mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "dependencies": {
    "@golden-abode/types": "workspace:*",
    "@expo-google-fonts/dm-mono": "^0.4.2",
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/poppins": "^0.4.1",
    "@hookform/resolvers": "^5.4.0",
    "@tanstack/react-query": "^5.101.0",
    "axios": "^1.18.0",
    "expo": "~56.0.12",
    "expo-constants": "~56.0.18",
    "expo-font": "~56.0.7",
    "expo-linking": "~56.0.14",
    "expo-router": "~56.2.11",
    "expo-secure-store": "^56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-hook-form": "^7.79.0",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "cross-env": "^7.0.3",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "cross-env APP_VARIANT=production expo start",
    "dev": "cross-env APP_VARIANT=development expo start",
    "prod": "cross-env APP_VARIANT=production expo start",
    "android:dev": "cross-env APP_VARIANT=development expo run:android",
    "android:prod": "cross-env APP_VARIANT=production expo run:android",
    "ios:dev": "cross-env APP_VARIANT=development expo run:ios --device",
    "ios:dev:sim": "cross-env APP_VARIANT=development expo run:ios",
    "ios:prod": "cross-env APP_VARIANT=production expo run:ios --device",
    "ios:prod:sim": "cross-env APP_VARIANT=production expo run:ios",
    "ios:release": "cross-env APP_VARIANT=production npx expo run:ios --configuration Release",
    "ios:release:device": "cross-env APP_VARIANT=production npx expo run:ios --configuration Release --device",
    "android:release": "cross-env APP_VARIANT=production npx expo run:android --variant release",
    "prebuild:dev": "cross-env APP_VARIANT=development npx expo prebuild --clean",
    "prebuild:prod": "cross-env APP_VARIANT=production npx expo prebuild --clean",
    "reset-project": "node ./scripts/reset-project.js",
    "verify:google-services": "node ./scripts/verify-google-services.js",
    "build:preview:android": "eas build --profile preview --platform android",
    "build:preview:ios": "eas build --profile preview --platform ios",
    "build:apk": "eas build --profile preview --platform android",
    "build:aab": "eas build --profile production --platform android",
    "build:ios": "eas build --profile production --platform ios",
    "submit:ios": "eas submit --profile production --platform ios",
    "submit:android": "eas submit --profile production --platform android",
    "type-check": "tsc --noEmit",
    "lint:fix": "eslint --fix .",
    "lint": "expo lint",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web"
  },
  "private": true
}
