# =============================================================
# Golden Abode Backend — Environment Variables
# =============================================================

NODE_ENV=development
PORT=3000

DB_HOST=localhost
DB_PORT=5432
DB_NAME=golden_abode
DB_USER=postgres
DB_PASS=postgres

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

JWT_ACCESS_SECRET=local_access_secret_for_dev_only
JWT_ACCESS_EXPIRES_IN=15m

JWT_ONBOARDING_SECRET=local_onboarding_secret_for_dev_only
JWT_ONBOARDING_EXPIRES_IN=15m

REFRESH_TOKEN_TTL_DAYS=30

MSG91_AUTH_KEY=mock_auth_key
MSG91_TEMPLATE_ID=mock_template_id
MSG91_SENDER_ID=GOLDEN

THROTTLE_OTP_SEND_LIMIT=3
THROTTLE_OTP_SEND_TTL=3600

THROTTLE_OTP_VERIFY_LIMIT=5
THROTTLE_OTP_VERIFY_TTL=600
